{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "@radix-ui/react-accessible-icon": "^1.1.8-rc.1747678980544",
    "@radix-ui/react-accordion": "^1.2.12-rc.1752791004720",
    "@radix-ui/react-alert-dialog": "^1.1.15-rc.1752791004720",
    "@radix-ui/react-aspect-ratio": "^1.1.8-rc.1747678980544",
    "@radix-ui/react-avatar": "^1.1.11-rc.1747678980544",
    "@radix-ui/react-checkbox": "^1.3.3-rc.1752791004720",
    "@radix-ui/react-collapsible": "^1.1.12-rc.1752791004720",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16-rc.1752791004720",
    "@radix-ui/react-hover-card": "^1.1.15-rc.1752791004720",
    "@radix-ui/react-label": "^2.1.8-rc.1747678980544",
    "@radix-ui/react-menubar": "^1.1.16-rc.1752791004720",
    "@radix-ui/react-navigation-menu": "^1.2.14-rc.1752791004720",
    "@radix-ui/react-progress": "^1.1.8-rc.1747678980544",
    "@radix-ui/react-radio-group": "^1.3.8-rc.1752791004720",
    "@radix-ui/react-select": "^2.2.6-rc.1752791004720",
    "@radix-ui/react-slider": "^1.3.6-rc.1752791004720",
    "@radix-ui/react-switch": "^1.2.6-rc.1752791004720",
    "@radix-ui/react-tabs": "^1.1.13-rc.1752791004720",
    "@radix-ui/react-toast": "^1.2.15-rc.1752791004720",
    "@radix-ui/react-toggle": "^1.1.10-rc.1752791004720",
    "@radix-ui/react-toggle-group": "^1.1.11-rc.1752791004720",
    "@sentry/nextjs": "^10.44.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "caniuse-lite": "^1.0.30001780",
    "framer-motion": "^12.38.0",
    "lru-cache": "^11.2.7",
    "nuqs": "^2.8.9",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cf/eslint-config": "workspace:*",
    "@cf/prettier-config": "workspace:*",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/cz-commitlint": "^20.5.0",
    "@faker-js/faker": "^10.3.0",
    "@manypkg/cli": "^0.25.1",
    "@next/bundle-analyzer": "^16.2.0",
    "@next/eslint-plugin-next": "^16.2.0",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@turbo/gen": "^2.8.18",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^3.2.4",
    "check-dependency-version-consistency": "^6.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "^2.8.18",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "netlify-plugin-cache": "^1.0.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "semantic-release": "^25.0.3",
    "syncpack": "^14.2.0",
    "tailwind-config-viewer": "^2.0.4",
    "turbo": "^2.8.18",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "bun@1.3.0",
  "prettier": "@cf/prettier-config",
  "resolutions": {
    "vite": "^5.4.21",
    "@vitejs/plugin-react": "^5.2.0",
    "vitest": "3.2.4",
    "@vitest/ui": "3.2.4"
  },
  "scripts": {
    "analyze": "ANALYZE=true turbo build",
    "build": "turbo build",
    "check-deps": "check-dependency-version-consistency .",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "commit": "cz",
    "deps:check": "syncpack lint",
    "deps:fix": "syncpack fix && syncpack format",
    "deps:lint": "syncpack lint",
    "deps:list": "syncpack list",
    "deps:update": "syncpack update",
    "dev": "turbo dev --parallel",
    "dev:auth-proxy": "turbo dev --filter=@cf/auth-proxy",
    "dev:buyer": "turbo dev --filter=@cf/buyer -- --port=3010",
    "dev:grower": "turbo dev --filter=@cf/grower",
    "dev:web": "turbo dev --parallel",
    "format": "turbo format --continue -- --cache --cache-location='node_modules/.cache/.prettiercache' --ignore-path='../../.gitignore'",
    "format:fix": "turbo format --continue -- --write --cache --cache-location='node_modules/.cache/.prettiercache' --ignore-path='../../.gitignore'",
    "gen": "turbo gen --config 'turbo/generators/config.ts'",
    "lint": "NODE_OPTIONS='--max-old-space-size=4096' turbo lint --continue && manypkg check",
    "lint:fix": "NODE_OPTIONS='--max-old-space-size=4096' turbo lint --continue -- --fix",
    "prepare": "node scripts/prepare-husky.cjs",
    "release": "semantic-release",
    "test": "vitest --config vitest.config.mts",
    "test:coverage": "vitest run --coverage --config vitest.config.mts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ui": "vitest --ui --config vitest.config.mts",
    "typecheck": "turbo typecheck"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ]
}
