{
  "name": "@cf/api",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "openapi-fetch": "^0.9.1",
    "openapi-react-query": "^0.2.3"
  },
  "devDependencies": {
    "@cf/eslint-config": "workspace:*",
    "@cf/prettier-config": "workspace:*",
    "@cf/typescript-config": "workspace:*",
    "@tanstack/react-query": "^5.51.11",
    "@types/node": "^24.9.1",
    "eslint": "^10.0.3",
    "openapi-typescript": "^7.0.0",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "typescript": "^5.9.3"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@cf/eslint-config/base"
    ]
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.51.11",
    "react": "^18.3.0"
  },
  "prettier": "@cf/prettier-config",
  "scripts": {
    "build": "echo 'Skipping OpenAPI generation in build'",
    "clean": "rm -rf .turbo node_modules",
    "codeGen": "openapi-typescript https://completefarmerapi-qa-f9g9bggnhdgdghf4.southafricanorth-01.azurewebsites.net/swagger/v1/swagger.json -o ./src/generated/types.ts",
    "format": "prettier --check '**/*.{ts,mjs}' ",
    "generate": "mkdir -p src/generated && openapi-typescript https://completefarmerapi-qa-f9g9bggnhdgdghf4.southafricanorth-01.azurewebsites.net/swagger/v1/swagger.json -o ./src/generated/types.ts",
    "typecheck": "tsc --noEmit"
  }
}
