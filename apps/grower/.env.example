# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# API Configuration
# For client-side API calls, the proxy pattern is used (see docs/api-proxy-pattern.md)
# This URL is only used for server-side API calls in development
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend API URL for the proxy route (optional, defaults to http://localhost:8000)
BACKEND_API_URL=http://localhost:8000

# API Proxy Configuration (optional)
API_PROXY_TIMEOUT=30000  # Request timeout in milliseconds (default: 30000)
MAX_REQUEST_SIZE=10485760  # Maximum request body size in bytes (default: 10MB)

# Upstash Redis Configuration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Password Reset Rate Limiting
AUTH_RESET_LIMIT_WINDOW_MIN=15
AUTH_RESET_LIMIT_MAX=10
AUTH_RESET_LIMIT_DAILY_MAX=30
AUTH_RESET_LIMIT_PER_IP=20
AUTH_RESET_LIMIT_BYPASS_FOR_TEST=false

# OTP Verification Rate Limiting
AUTH_OTP_LIMIT_MAX=3
AUTH_OTP_LIMIT_WINDOW_MIN=15
AUTH_OTP_LOCKOUT_MIN=15
AUTH_OTP_LIMIT_BYPASS_FOR_TEST=false

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0

# Mapbox Configuration
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Invitation Configuration
INVITATION_EXPIRATION_HOURS=24  # Invitation link expiration time in hours (default: 24)

# Cookie Security (required for server-side auth)
COOKIE_ENCRYPTION_SECRET=
COOKIE_SIGNING_SECRET=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=