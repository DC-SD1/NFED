{
  "extends": "@cf/typescript-config/base",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["vitest/globals"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/app/[locale]/onboarding/newbie/commitment"
  ],
  "exclude": ["node_modules"]
}
